option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: assessmentPrishni.wsgi:application
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: static
    /media: media

container_commands:
  02_collectstatic:
    command: "/var/app/venv/*/bin/python manage.py collectstatic --noinput"
    leader_only: true